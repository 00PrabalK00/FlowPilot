# Copy to backend/.env and fill the provider you want. Keys stay server-side only.
# Pick ONE provider:
FLOWPILOT_PROVIDER=mock        # mock | claude | openai | gemini | ollama

# --- Claude (Anthropic) ---
# FLOWPILOT_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-opus-4-8

# --- OpenAI / Codex / GPT ---
# FLOWPILOT_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# --- Google Gemini (AI Studio key) ---
# FLOWPILOT_PROVIDER=gemini
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.0-flash

# --- Local Ollama (no key) ---
# FLOWPILOT_PROVIDER=ollama
# OLLAMA_MODEL=llama3.1
# OLLAMA_URL=http://127.0.0.1:11434

# Point at a real Node-RED (connector reads NODERED_URL, not backend):
# NODERED_URL=http://127.0.0.1:1880
